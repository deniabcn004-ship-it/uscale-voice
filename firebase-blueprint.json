{
  "entities": {
    "User": {
      "title": "User",
      "description": "User account containing credit balance and basic info",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string" },
        "username": { "type": "string" },
        "credits": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "isAdmin": { "type": "boolean" }
      },
      "required": ["uid", "email", "username", "credits"]
    },
    "SystemSettings": {
      "title": "System Settings",
      "description": "System-wide settings such as default credits and Gemini API key override",
      "type": "object",
      "properties": {
        "defaultEntryCredits": { "type": "number" },
        "geminiApiKey": { "type": "string" }
      },
      "required": ["defaultEntryCredits"]
    },
    "Voiceover": {
      "title": "Voiceover",
      "description": "An adapted script and the generated voiceover audio",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "originalText": { "type": "string" },
        "adaptedArabic": { "type": "string" },
        "adaptedLatin": { "type": "string" },
        "region": { "type": "string" },
        "voice": { "type": "string" },
        "speed": { "type": "string" },
        "emotion": { "type": "string" },
        "audioBase64": { "type": "string" },
        "mimeType": { "type": "string" },
        "timestamp": { "type": "string" },
        "vibeDescription": { "type": "string" },
        "pronunciationGuide": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "originalText", "adaptedArabic", "audioBase64", "mimeType"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "User",
      "description": "Collection of user profiles and credits"
    },
    "/settings/system": {
      "schema": "SystemSettings",
      "description": "System settings managed by the Admin"
    },
    "/voiceovers/{voiceoverId}": {
      "schema": "Voiceover",
      "description": "Collection of voiceovers generated by users"
    }
  }
}
