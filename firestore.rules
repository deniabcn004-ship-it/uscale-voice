rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Global safety net (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Core Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'deniabcn004@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // 2. Rules for User Accounts & Credits
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isSignedIn() && isOwner(userId);
      // Prevent users from editing their own credit balance or admin flags
      allow update: if isAdmin() || (
        isOwner(userId) && 
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['credits', 'isAdmin'])
      );
      allow delete: if isAdmin();
    }

    // 3. Rules for System Settings (Credits & Gemini API Key)
    match /settings/system {
      allow read: if isAdmin(); // Only admins can fetch system settings directly via client SDK
      allow write: if isAdmin();
    }

    // 4. Rules for Voiceover Recordings
    match /voiceovers/{voiceoverId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isSignedIn() && resource.data.userId == request.auth.uid && request.resource.data.userId == request.auth.uid;
      allow delete: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
    }

    // 5. Explicit Admins Directory Lookup
    match /admins/{adminId} {
      allow read, write: if isAdmin();
    }
  }
}
